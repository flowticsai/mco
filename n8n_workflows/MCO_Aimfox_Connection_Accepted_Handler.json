    },
    {
      "parameters": {
        "model": "claude-sonnet-4-6",
        "options": {
          "systemPrompt": "You are a senior sales development representative for Nextus AI. A lead has just accepted your LinkedIn connection request. Write a warm, genuine first LinkedIn message to open the conversation.\n\nRules:\n- Maximum 80 words \u2014 LinkedIn messages must be brief\n- Reference the context of how you reached out (email, prior interaction) to show continuity\n- Be conversational, not salesy \u2014 this is the start of a dialogue\n- No greeting or sign-off \u2014 just the message body\n- No bullet points, no formatting, no emojis\n- Use the lead's real name, never placeholders\n- Output ONLY the message text"
        }
      },
      "id": "accepted-ai-model",
      "name": "LinkedIn: Claude Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1.3,
      "position": [
        1740,
        440
      ],
      "credentials": {
        "anthropicApi": {
          "id": "tFYLbQt9S6IzWYNd",
          "name": "Anthropic account"
        }
      }
    },
