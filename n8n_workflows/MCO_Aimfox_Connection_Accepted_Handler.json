            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "c99e4025-9d25-4057-ac19-b9117acd3632",
      "name": "Fetch Context",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const extracted = $('Extract LEAD_EMAIL').first().json;\nconst ctx = $input.first().json;\nconst lead = ctx.lead || {};\nreturn [{ json: {\n  ...extracted,\n  context_block: ctx.context_block || '(No prior conversation history.)',\n  overall_intent: ctx.overall_intent || 'unknown',\n  lead_name: lead.full_name || extracted.lead_name,\n  lead_company: lead.company || ''\n}}];"
      },
      "id": "4a41378e-accd-43c1-a025-f1955040a2f7",
      "name": "Merge Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        0
      ]
    },
    {
      "parameters": {
        "model": "claude-sonnet-4-6",
        "options": {}
      },
      "id": "ee96187b-2b81-497e-858e-9a12b73ccb38",
      "name": "LinkedIn: Claude Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1.3,
      "position": [
        448,
        192
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ 'Write a LinkedIn message to ' + $json.lead_name + ($json.lead_company ? ' at ' + $json.lead_company : '') + ' who just accepted our connection request.\\n\\nOverall intent: ' + $json.overall_intent + '\\n\\nContext (prior interactions across all channels):\\n' + $json.context_block }}"
      },
      "id": "8d548887-9d94-4447-b975-8b0e6b4d7532",
      "name": "Generate Message",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.4,
      "position": [
        448,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const ctx = $('Merge Context').first().json;\nconst aiOutput = $input.first().json;\nconst message = (aiOutput.text || aiOutput.output || '').trim();\nif (!message) throw new Error('AI returned empty message');\nreturn [{ json: { ...ctx, generated_message: message } }];"
      },
      "id": "f6529ecb-aecd-4b2e-8158-7e7c6cfc4a31",
      "name": "Extract Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ 'https://api.aimfox.com/api/v2/accounts/' + $json.account_id + '/conversations' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ $json.AIMFOX_TOKEN }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ message: $json.generated_message, recipients: [$json.lead_id] }) }}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "85968d9d-ba8e-45ae-856e-ff299838cb70",
      "name": "Send via Start Conversation",
      "type": "n8n-nodes-base.httpRequest",
