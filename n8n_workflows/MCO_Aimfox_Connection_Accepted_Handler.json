    {
      "parameters": {
        "jsCode": "const SUPABASE_URL = 'https://hkqssbomrcbtfbdowtgj.supabase.co';\nconst SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhrcXNzYm9tcmNidGZiZG93dGdqIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3Nzg3MTU1MywiZXhwIjoyMDkzNDQ3NTUzfQ.sIW3-eY1IVz1CuErVL9k_2IC9LX1nBS_S9wkT__RgoI';\nconst AIMFOX_TOKEN = 'Bearer 8e65df8c-3fe2-4ecf-bf05-8261ea85464b';\nconst FETCH_CONTEXT_URL = 'https://nextus.app.n8n.cloud/webhook/mco-fetch-context';\nconst WRITE_EVENT_URL = 'https://nextus.app.n8n.cloud/webhook/mco-write-event';\n\nconst body = $input.first().json.body || $input.first().json;\n\n// Aimfox accepted event payload\nconst account_id = body.account_id || body.accountId || null;\nconst lead = body.lead || {};\nconst lead_id = lead.id || body.lead_id || null;\nconst lead_urn = lead.urn || body.lead_urn || null;\nconst lead_name = [lead.first_name, lead.last_name].filter(Boolean).join(' ') || 'there';\nconst linkedin_profile_url = lead.profile_url || lead.linkedin_url || null;\n\nif (!account_id) throw new Error('No account_id in Aimfox accepted payload');\nif (!lead_id && !lead_urn) throw new Error('No lead_id or lead_urn in payload');\n\nreturn [{ json: {\n  SUPABASE_URL, SUPABASE_KEY, AIMFOX_TOKEN,\n  FETCH_CONTEXT_URL, WRITE_EVENT_URL,\n  account_id: String(account_id),\n  lead_id: String(lead_id || ''),\n  lead_urn: lead_urn || '',\n  lead_name,\n  linkedin_profile_url\n}}];"
      },
      "id": "accepted-extract",
      "name": "Extract Fields",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        420,
        400
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://api.aimfox.com/api/v2/accounts/' + $json.account_id + '/leads/' + $json.lead_urn + '/custom-variables' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ $json.AIMFOX_TOKEN }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
