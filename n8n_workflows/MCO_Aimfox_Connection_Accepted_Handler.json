        },
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "accepted-get-vars",
      "name": "Get Lead Custom Variables",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        640,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "const extracted = $('Extract Fields').first().json;\nconst varsResp = $input.first().json;\n\n// Custom variables may be nested differently depending on Aimfox response shape\nconst vars = varsResp.custom_variables || varsResp.variables || varsResp || {};\nconst lead_email = vars.LEAD_EMAIL || vars.lead_email || null;\n\nreturn [{ json: {\n  ...extracted,\n  lead_email,\n  has_email: !!lead_email\n}}];"
      },
      "id": "accepted-extract-email",
      "name": "Extract LEAD_EMAIL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        400
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {},
          "conditions": [
            {
              "id": "e1",
              "leftValue": "={{ $json.has_email }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "accepted-has-email",
      "name": "Has Email?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1080,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\nconsole.log('Accepted event skipped \u2014 no LEAD_EMAIL in custom variables. lead_id:', d.lead_id);\nreturn [{ json: { skipped: true, reason: 'No LEAD_EMAIL in Aimfox custom variables', lead_id: d.lead_id } }];"
      },
