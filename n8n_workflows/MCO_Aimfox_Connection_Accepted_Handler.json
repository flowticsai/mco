        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  event_id: $('Extract Message').first().json.account_id + '-accepted-' + $('Extract Message').first().json.lead_id + '-' + Date.now(),\n  lead_email: $('Extract Message').first().json.lead_email,\n  timestamp: new Date().toISOString(),\n  channel: 'linkedin',\n  direction: 'outbound',\n  content: $('Extract Message').first().json.generated_message,\n  content_type: 'message',\n  sender_name: 'Anik Hanik',\n  intent: 'no_action',\n  metadata: {\n    platform_account_id: $('Extract Message').first().json.account_id,\n    platform_conversation_id: null,\n    triggered_by: 'connection_accepted'\n  },\n  workflow_execution_id: 'aimfox-accepted-handler'\n}) }}",
        "options": {
